# Copy to .env and fill in. .env is gitignored; never commit real secrets.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# NCBI E-utilities, used by the PubMed MCP connector (.mcp.json) and the runtime app.
# NCBI_ADMIN_EMAIL must be the email registered to the API key.
# Get a key: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_ADMIN_EMAIL=you@institution.edu
NCBI_API_KEY=your-ncbi-api-key

# ── Optional runtime overrides (all have sensible defaults; leave unset for the demo) ──
# PANOSCOPE_MODEL=claude-sonnet-4-6        # Claude model the agent uses
# PANOSCOPE_DATASET=xenium_hbreast_sample1 # which data/datasets/<id> tree to load
# PANOSCOPE_CONTEXT_DIR=context            # where lab notes + user memory are stored
