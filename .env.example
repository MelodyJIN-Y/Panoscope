# Copy to .env and fill in. .env is gitignored; never commit real secrets.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# NCBI E-utilities, used by the PubMed MCP connector (.mcp.json) and the runtime app.
# NCBI_ADMIN_EMAIL must be the email registered to the API key.
# Get a key: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_ADMIN_EMAIL=you@institution.edu
NCBI_API_KEY=your-ncbi-api-key
