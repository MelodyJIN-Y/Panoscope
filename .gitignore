scripts/demo_grounding_veto.py
scripts/demo_second_opinion.py

# ── Large input data (exceeds GitHub's 100 MB/file limit — never commit) ─────
# Raw Xenium inputs (~1.4 GB, incl. transcripts.csv.gz 1.3 GB)
Raw_data_Xenium_hbreast_sample1/
# jazzPanda outputs live here; xenium_hbreast_seu.Rds alone is 328 MB.
# Whole dir ignored for now — small precomputed outputs get committed under
# data/jazzpanda/ once the repo layout is set up.
jazzPanda output/

# Defensive: never let big bio-data blobs in even if relocated
*.csv.gz
*.mtx.gz
*.h5
*.h5ad
xenium_hbreast_seu.Rds

# Fat raw expression matrix (280 genes × all cells, ~55 MB); the committed
# artifact is the subsampled data/embeddings/marker_expr.parquet.
data/embeddings/marker_expr.csv

